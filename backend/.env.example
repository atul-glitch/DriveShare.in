NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
CORS_ORIGIN=http://localhost:8000
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

RAZORPAY_KEY_ID=rzp_test_example
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-secret
ALLOW_MOCK_PAY=true

ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=change-me-before-deploy
ADMIN_EMAIL=admin@carrental.com
ADMIN_FULL_NAME=Admin
